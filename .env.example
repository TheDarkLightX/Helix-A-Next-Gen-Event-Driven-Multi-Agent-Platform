HELIX_API_ADDR=127.0.0.1:3000

# Compose/Postgres defaults
POSTGRES_DB=helix
POSTGRES_USER=helix
POSTGRES_PASSWORD=helix_dev_password
HELIX_API_PORT=3000
HELIX_POSTGRES_PORT=5432
# Enables durable intelligence desk, policy, and autopilot guard state when the
# API can reach this database.
DATABASE_URL=postgres://helix:helix_dev_password@127.0.0.1:5432/helix
# When true, the API applies the bundled idempotent SQL migration at startup.
HELIX_AUTO_MIGRATE=true
# Required for credential vault writes. Generate a deployment key with:
# openssl rand -hex 32
HELIX_ENCRYPTION_KEY=

# API auth
# Local development can leave auth disabled. Set HELIX_AUTH_REQUIRED=true in
# shared or production deployments and provide a long random token.
HELIX_AUTH_REQUIRED=false
HELIX_API_TOKEN=

# Autopilot defaults
HELIX_AUTOPILOT_MODE=assist
HELIX_AUTOPILOT_ALLOW_ONCHAIN=false
HELIX_AUTOPILOT_REQUIRE_ONCHAIN_CONFIRMATION=true
HELIX_AUTOPILOT_REQUIRE_DRY_RUN=true
HELIX_AUTOPILOT_MAX_POLICY_COMMANDS=128

# Autopilot proposal (LLM)
# Provide an OpenAI-compatible endpoint (OpenAI, OpenRouter, or self-hosted vLLM/Qwen).
HELIX_AUTOPILOT_LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
LLM_BASE_URL=
